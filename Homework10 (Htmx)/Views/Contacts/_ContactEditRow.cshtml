@model Contact

<tr hx-target="this" hx-swap="outerHTML" class="table-info">
    <td colspan="4">
        <form hx-put="/Contacts/@Model.Id/Edit" hx-indicator="#spinner-@Model.Id">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <input type="text" name="Name" class="form-control form-control-sm" 
                           value="@Model.Name" placeholder="Name" required />
                </div>
                <div class="col">
                    <input type="email" name="Email" class="form-control form-control-sm" 
                           value="@Model.Email" placeholder="Email" />
                </div>
                <div class="col">
                    <input type="text" name="Phone" pattern="^+[0-9+]*$" class="form-control form-control-sm" 
                           value="@Model.Phone" placeholder="Phone" />
                </div>
                <div class="col-auto d-flex align-items-center">
                    <button type="submit" class="btn btn-sm btn-success me-1">Save</button>
                    
                    <button type="button" class="btn btn-sm btn-secondary" 
                            hx-get="/Contacts/@Model.Id/Row">
                        Cancel
                    </button>

                    <div id="spinner-@Model.Id" class="htmx-indicator spinner-border spinner-border-sm text-primary ms-2" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </form>
    </td>
</tr>