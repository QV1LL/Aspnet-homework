@model IReadOnlyCollection<Contact>

@{
    ViewData["Title"] = "Contacts Management";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-primary m-0">
                    <i class="bi bi-person-lines-fill"></i> My Contacts
                </h2>
                
                <div class="position-relative w-50">
                    <span class="position-absolute top-50 start-0 translate-middle-y ps-3 text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input
                        type="text"
                        name="query"
                        class="form-control form-control-lg ps-5 border-2 shadow-sm"
                        style="border-radius: 25px;"
                        hx-get="/Contacts/Search"
                        hx-trigger="input changed delay:300ms"
                        hx-target="#contact-table-body"
                        placeholder="Search by name..."
                    />
                </div>
            </div>

            @* Картка з таблицею *@
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4 py-3 text-uppercase fs-7 text-muted">Name</th>
                                    <th class="py-3 text-uppercase fs-7 text-muted">Email</th>
                                    <th class="py-3 text-uppercase fs-7 text-muted">Phone</th>
                                    <th class="pe-4 py-3 text-end text-uppercase fs-7 text-muted">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="contact-table-body">
                                <partial name="_ContactRows" model="Model" />
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="mt-5 p-4 bg-light rounded-4 border border-dashed border-primary border-2">
                <h4 class="mb-3 text-secondary">Add New Contact</h4>
                <partial name="_CreateContact" />
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
}