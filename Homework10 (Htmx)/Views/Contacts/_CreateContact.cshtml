<form hx-post="/Contacts/Create" 
      hx-target="#contact-table-body" 
      hx-swap="beforeend"
      hx-on::after-request="if(event.detail.successful) this.reset()"
      class="mb-4">
    
    <div class="row">
        <div class="col">
            <input type="text" name="Name" class="form-control" placeholder="Ім'я" required />
        </div>
        <div class="col">
            <input type="email" name="Email" class="form-control" placeholder="Email" />
        </div>
        <div class="col">
            <input type="text" name="Phone" pattern="^+[0-9+]*$" class="form-control" placeholder="Телефон" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-success">Додати</button>
        </div>
    </div>
</form>